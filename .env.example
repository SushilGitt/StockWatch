# =============================================================================
# StockWatch — environment variables
# =============================================================================
# This is a TEMPLATE. Copy it to `.env` and fill in real values for local use:
#     cp .env.example .env
# In production these are set in Coolify (App -> Environment Variables), NOT here.
# Never commit a real `.env` — it is gitignored. Only this `.env.example` is tracked.
#
# NOTE: the app reads from process.env directly (it does not auto-load a .env
# file). To make a local `.env` actually load, add `dotenv` — ask and we'll wire
# it up. For Coolify these names just need to exist as env vars.
# =============================================================================

# --- Shopify app (REQUIRED) --------------------------------------------------
# From your Shopify Partner Dashboard -> App -> Client credentials.
# SHOPIFY_API_KEY is also injected into the frontend (index.html) at build time.
SHOPIFY_API_KEY=your_app_client_id
SHOPIFY_API_SECRET=your_app_client_secret
# Comma-separated access scopes the app requests.
SCOPES=read_inventory,read_products
# Public HTTPS URL of the deployed app (NO trailing slash). Used for the OAuth
# callback and the webhook callback URL. HOST and SHOPIFY_APP_URL are the same.
HOST=https://your-app-domain.example.com
SHOPIFY_APP_URL=https://your-app-domain.example.com

# --- Server ------------------------------------------------------------------
# Port the Express server listens on (Coolify uses 3000).
PORT=3000
# production | development
NODE_ENV=production

# --- Database ----------------------------------------------------------------
# MongoDB connection string. Stores Store + Threshold documents.
MONGODB_URI=mongodb://user:password@host:27017/Stock_Sentinel

# --- Email / SMTP (Nodemailer, used for low-stock alerts) --------------------
# Gmail address used as the SMTP login AND the visible sender.
EMAIL_USER=your-address@gmail.com
# Gmail APP PASSWORD (16 chars) — NOT your normal account password.
# Requires 2-Step Verification: Google Account -> Security -> App passwords.
EMAIL_PASS=your_gmail_app_password
# Optional. From header. Defaults to: "StockWatch" <EMAIL_USER>.
# WARNING: do NOT set this in Coolify with quotes — Coolify escapes them and it
# breaks the SMTP envelope (555 error). Leave it unset to use the safe default.
# EMAIL_FROM="StockWatch" <your-address@gmail.com>
# Optional. SMTP host / port. Default to Gmail STARTTLS.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587

# --- Billing -----------------------------------------------------------------
# Optional. Defaults to PRODUCTION (real charges via the Shopify Billing API).
# Set to "true" to force TEST charges (no real money) even on a live store, e.g.
# for staging. Dev/test stores are always billed as test regardless.
# BILLING_TEST=true

# --- Frontend build / local dev only -----------------------------------------
# These are used by web/frontend/vite.config.js and are normally set
# automatically by the Shopify CLI during `shopify app dev`. Not needed in
# the Coolify/Docker production runtime.
# FRONTEND_PORT=
# BACKEND_PORT=
# CI=
